# Database
DATABASE_URL=data/ghost-writer.sqlite

# Author auth (dev bypass): if set, this email auto-logs in as the single author.
DEV_AUTHOR_EMAIL=

# JWT for interviewee links
JWT_SECRET=change-me-to-32-bytes-of-random-base64

# Claude CLI
# Path to the claude executable. Leave blank to resolve from PATH.
CLAUDE_CLI_BIN=

# Groq Whisper (Phase 7+)
GROQ_API_KEY=

# Resend (production magic links — Phase 10+)
RESEND_API_KEY=
RESEND_FROM=

# Public URL for interviewee links (used when generating magic links)
PUBLIC_BASE_URL=http://localhost:3000
